{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --omit=dev --no-audit --no-fund"
  },
  "deploy": {
    "startCommand": "node agent/monitor.mjs",
    "cronSchedule": "*/10 * * * *",
    "restartPolicyType": "NEVER"
  }
}
